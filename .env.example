# Copy this file to .env and replace placeholder values with strong, unique secrets.
# NEVER commit the .env file to version control.

# PostgreSQL credentials
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD
POSTGRES_DB=n8n

# n8n secrets — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
